---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Page not found — ${SITE_TITLE}`}
			description="The page you were looking for could not be found."
			noindex={true}
			preloadFonts={['--font-atkinson']}
		/>
		<style>
			main {
				min-height: 60vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
			}
			.code {
				font-size: 5rem;
				margin: 0;
				color: var(--accent);
				line-height: 1;
			}
			h1 {
				margin: 0.25em 0 0.5em;
			}
			p {
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.links {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
				justify-content: center;
			}
			.links a {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<p class="code">404</p>
			<h1>Page not found</h1>
			<p>The page you were looking for doesn't exist or has moved.</p>
			<div class="links">
				<a href="/">Go home</a>
				<a href="/blog">Read the blog</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
