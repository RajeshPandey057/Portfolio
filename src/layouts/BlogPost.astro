---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { AUTHOR } from '../consts';
import { blogPostGraph } from '../lib/seo';

type Props = CollectionEntry<'blog'>['data'] & {
	slug: string;
	readingTime: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	heroImageAlt,
	tags = [],
	author = AUTHOR.name,
	slug,
	readingTime,
} = Astro.props;

const path = `/blog/${slug}/`;
const ogImage = heroImage
	? new URL(heroImage.src, Astro.site).href
	: new URL('/og.png', Astro.site).href;

const schema = blogPostGraph(Astro.site, {
	title,
	description,
	path,
	pubDate,
	updatedDate,
	image: ogImage,
	imageAlt: heroImageAlt,
	tags,
});
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} — ${AUTHOR.name}`}
			description={description}
			image={heroImage}
			imageAlt={heroImageAlt ?? title}
			type="article"
			publishedTime={pubDate}
			modifiedTime={updatedDate}
			tags={tags}
			canonicalPath={path}
			preloadFonts={['--font-atkinson']}
			schema={schema}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.breadcrumb {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.breadcrumb a {
				color: rgb(var(--gray));
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.meta {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.meta .sep {
				margin: 0 0.4em;
				opacity: 0.5;
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				margin-top: 1em;
				list-style: none;
				padding: 0;
			}
			.tags li {
				font-size: 0.8rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 100px;
				padding: 0.25em 0.8em;
				color: rgb(var(--gray));
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt={heroImageAlt ?? title}
							/>
						</div>
					)
				}
				<div class="prose">
					<nav class="breadcrumb" aria-label="Breadcrumb">
						<a href="/">Home</a> / <a href="/blog">Blog</a> / <span>{title}</span>
					</nav>
					<div class="title">
						<div class="meta">
							<FormattedDate date={pubDate} />
							<span class="sep">·</span>
							{readingTime} min read
							<span class="sep">·</span>
							<span>{author}</span>
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							tags.length > 0 && (
								<ul class="tags">
									{tags.map((tag) => (
										<li>{tag}</li>
									))}
								</ul>
							)
						}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
