---
// Global <head> for every page: canonical, robots, full Open Graph + Twitter,
// self-hosted font preloads, favicons/manifest, and schema.org JSON-LD.
import '../styles/global.css';
import { Font } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
	AUTHOR,
	OG_IMAGE,
	SITE_KEYWORDS,
	SITE_LOCALE,
	SITE_TITLE,
} from '../consts';

interface Props {
	title: string;
	description: string;
	/** ImageMetadata (optimized asset) or an absolute-from-root path string. Defaults to the brand OG card. */
	image?: ImageMetadata | string;
	imageAlt?: string;
	imageWidth?: number;
	imageHeight?: number;
	type?: 'website' | 'article' | 'profile';
	publishedTime?: Date;
	modifiedTime?: Date;
	tags?: string[];
	noindex?: boolean;
	/** Override the canonical path (defaults to the current pathname). */
	canonicalPath?: string;
	/** CSS variables of fonts to <link rel=preload> for this page's critical text. */
	preloadFonts?: string[];
	/** schema.org JSON-LD graph(s). */
	schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title,
	description,
	image,
	imageAlt,
	imageWidth,
	imageHeight,
	type = 'website',
	publishedTime,
	modifiedTime,
	tags = [],
	noindex = false,
	canonicalPath,
	preloadFonts = [],
	schema,
} = Astro.props;

const canonicalURL = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);

// Resolve the share image to an absolute URL with known dimensions + alt.
let ogSrc: string;
let ogWidth: number | undefined;
let ogHeight: number | undefined;
let ogAlt: string;
if (!image) {
	ogSrc = OG_IMAGE.src;
	ogWidth = OG_IMAGE.width;
	ogHeight = OG_IMAGE.height;
	ogAlt = imageAlt ?? OG_IMAGE.alt;
} else if (typeof image === 'string') {
	ogSrc = image;
	ogWidth = imageWidth;
	ogHeight = imageHeight;
	ogAlt = imageAlt ?? title;
} else {
	ogSrc = image.src;
	ogWidth = image.width;
	ogHeight = image.height;
	ogAlt = imageAlt ?? title;
}
const ogImageURL = new URL(ogSrc, Astro.site).href;

const robots = noindex
	? 'noindex, nofollow'
	: 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const fontVars = ['--font-atkinson', '--font-inter', '--font-newsreader', '--font-mono'];
const schemaList = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!-- Global metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Icons & manifest -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#100d0a" />
<meta name="color-scheme" content="dark light" />

<!-- Fonts: inject @font-face for all families, preload only this page's critical ones -->
{fontVars.map((v) => <Font cssVariable={v} preload={preloadFonts.includes(v)} />)}

<!-- Canonical + feeds + sitemap -->
<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={`${SITE_TITLE} — Blog`}
	href={new URL('rss.xml', Astro.site)}
/>

<!-- Primary meta -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={AUTHOR.name} />
<meta name="keywords" content={SITE_KEYWORDS.join(', ')} />
<meta name="robots" content={robots} />
<meta name="googlebot" content={robots} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={SITE_LOCALE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={ogAlt} />
{ogWidth && <meta property="og:image:width" content={String(ogWidth)} />}
{ogHeight && <meta property="og:image:height" content={String(ogHeight)} />}

{type === 'profile' && <meta property="profile:first_name" content={AUTHOR.givenName} />}
{type === 'profile' && <meta property="profile:last_name" content={AUTHOR.familyName} />}

{type === 'article' && publishedTime && (
	<meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{type === 'article' && (
	<meta
		property="article:modified_time"
		content={(modifiedTime ?? publishedTime ?? new Date()).toISOString()}
	/>
)}
{type === 'article' && <meta property="article:author" content={AUTHOR.name} />}
{type === 'article' &&
	tags.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={ogAlt} />

<!-- Structured data -->
{schemaList.map((node) => (
	<script type="application/ld+json" set:html={JSON.stringify(node)} />
))}
